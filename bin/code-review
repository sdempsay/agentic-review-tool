#!/usr/bin/env bash
set -euo pipefail

# Run from a directory on your PATH with code-review.jar beside this script:
#   ~/tools/code-review/code-review
#   ~/tools/code-review/code-review.jar
#
# Build the JAR: mvn package -DskipTests  (output: target/code-review.jar)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JAR="${SCRIPT_DIR}/code-review.jar"

if [[ ! -f "${JAR}" ]]; then
  echo "code-review: missing ${JAR}" >&2
  echo "Copy target/code-review.jar next to this script." >&2
  exit 1
fi

JAVA_BIN="$(which java 2>/dev/null || true)"
if [[ -z "${JAVA_BIN}" ]]; then
  if [[ -n "${JAVA_HOME:-}" && -x "${JAVA_HOME}/bin/java" ]]; then
    JAVA_BIN="${JAVA_HOME}/bin/java"
  else
    echo "code-review: java not found on PATH (which java) and JAVA_HOME is unset or invalid" >&2
    echo "Install Java 21+ or set JAVA_HOME." >&2
    exit 1
  fi
fi

exec "${JAVA_BIN}" ${JAVA_OPTS:-} -jar "${JAR}" "$@"